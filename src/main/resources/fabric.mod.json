{
  "schemaVersion": 1,
  "id": "iqaddons",
  "version": "${version}",
  "name": "IQ",
  "description": "IQ is a Hypixel SkyBlock mod made especially for Kuudra.\nWhile it includes a few general features, most of them are Kuudra-focused.",
  "authors": [
    "PeHenrii",
    "DarkJota"
  ],
  "contact": {
    "homepage": "https://github.com/pehenrii/IQ",
    "sources": "https://github.com/pehenrii/IQ",
    "issues": "https://discord.gg/HdhXhCWcW9",
    "discord": "https://discord.gg/HdhXhCWcW9"
  },
  "license": "MIT",
  "icon": "assets/iq/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "net.iqaddons.mod.IQModClient"
    ],
    "modmenu": [
      "net.iqaddons.mod.integration.ModMenuIntegration"
    ]
  },
  "mixins": [
    "iq.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "java": ">=25",
    "minecraft": "${minecraft_version}"
  }
}
